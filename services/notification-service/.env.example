APP_NAME=NotificationService
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8005

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=notification_db
DB_USERNAME=notification_user
DB_PASSWORD=secret

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="SaaS Inventory"

CACHE_DRIVER=redis
QUEUE_CONNECTION=rabbitmq

WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_BACKOFF=60

LOG_CHANNEL=stack
LOG_LEVEL=debug
