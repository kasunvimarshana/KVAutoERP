APP_NAME="Tenant Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8002
APP_VERSION=1.0.0

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=tenant_service
DB_USERNAME=tenant_user
DB_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="tenant@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Multi-tenancy
TENANCY_MODE=single
TENANT_ROOT_DOMAIN=example.com
TENANT_ROOT_DOMAIN_PARTS=2
TENANT_CACHE_TTL=300
TENANT_DEFAULT_MAX_USERS=100
TENANT_DEFAULT_MAX_ORGS=10
TENANT_DEFAULT_PLAN=free
TENANT_TRIAL_DAYS=14

# Runtime config flags
TENANT_RUNTIME_DB=true
TENANT_RUNTIME_MAIL=true
TENANT_RUNTIME_CACHE=true
TENANT_RUNTIME_BROKER=false

# Webhook settings
WEBHOOK_DEFAULT_RETRY_COUNT=3
WEBHOOK_TIMEOUT=10

# RabbitMQ (optional)
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
