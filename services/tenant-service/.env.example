APP_NAME=TenantService
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8002

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=tenant_db
DB_USERNAME=tenant_user
DB_PASSWORD=secret

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=rabbitmq

DEFAULT_TENANT_PLAN=free
TENANT_TRIAL_DAYS=14
TENANT_CONFIG_CACHE_TTL=3600

LOG_CHANNEL=stack
LOG_LEVEL=debug
