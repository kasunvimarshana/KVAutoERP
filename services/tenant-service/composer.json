{
  "name": "kv-saas/tenant-service",
  "description": "Tenant microservice - Multi-tenant provisioning, configuration, and lifecycle management",
  "type": "project",
  "require": {
    "php": "^8.3",
    "laravel/framework": "^11.0",
    "guzzlehttp/guzzle": "^7.0",
    "predis/predis": "^2.0",
    "ramsey/uuid": "^4.0",
    "php-amqplib/php-amqplib": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "fakerphp/faker": "^1.0",
    "mockery/mockery": "^1.6"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "App\\Shared\\": "../../shared/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "start": "php artisan serve --port=8003"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
