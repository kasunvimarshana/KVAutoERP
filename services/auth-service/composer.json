{
  "name": "kv-saas/auth-service",
  "description": "Auth microservice - Laravel Passport SSO with RBAC/ABAC",
  "type": "project",
  "require": {
    "php": "^8.3",
    "laravel/framework": "^11.0",
    "laravel/passport": "^12.0",
    "tymon/jwt-auth": "^2.1",
    "spatie/laravel-permission": "^6.0",
    "predis/predis": "^2.0",
    "guzzlehttp/guzzle": "^7.0",
    "ramsey/uuid": "^4.0",
    "php-amqplib/php-amqplib": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "fakerphp/faker": "^1.0",
    "mockery/mockery": "^1.6"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "App\\Shared\\": "../../shared/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "start": "php artisan serve --port=8001"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
