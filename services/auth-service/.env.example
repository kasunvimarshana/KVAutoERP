# ─── Application ────────────────────────────────────────────────────────────
APP_NAME="KV_SAAS Auth Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001
APP_VERSION=1.0.0

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database ─────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=auth-db
DB_PORT=3306
DB_DATABASE=auth_service
DB_USERNAME=auth_user
DB_PASSWORD=secret

# ─── Cache / Session / Queue ──────────────────────────────────────────────────
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# ─── Laravel Passport ────────────────────────────────────────────────────────
PASSPORT_TOKEN_EXPIRY=60
PASSPORT_REFRESH_TOKEN_EXPIRY=30
PASSPORT_PAT_EXPIRY=6
PASSPORT_PRIVATE_KEY=
PASSPORT_PUBLIC_KEY=
PASSPORT_PERSONAL_ACCESS_CLIENT_ID=
PASSPORT_PERSONAL_ACCESS_CLIENT_SECRET=

# ─── Spatie Permission ────────────────────────────────────────────────────────
PERMISSION_TEAMS=true
PERMISSION_CACHE_STORE=redis

# ─── Message Broker (RabbitMQ) ────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=kv_saas_events

# ─── Multi-Tenant ────────────────────────────────────────────────────────────
TENANT_HEADER=X-Tenant-ID

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=*

# ─── Service Discovery ───────────────────────────────────────────────────────
INVENTORY_SERVICE_URL=http://inventory-service:8002
ORDER_SERVICE_URL=http://order-service:8003
