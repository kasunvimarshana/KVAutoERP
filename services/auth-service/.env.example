APP_NAME="KV Auth Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql-auth
DB_PORT=3306
DB_DATABASE=auth_db
DB_USERNAME=auth_user
DB_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=rabbitmq
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Multi-tenant settings
TENANT_ID=default
TENANT_NAME="Default Tenant"
TENANT_DB_HOST=mysql-auth
TENANT_DB_PORT=3306
TENANT_DB_DATABASE=auth_db
TENANT_DB_USERNAME=auth_user
TENANT_DB_PASSWORD=secret

# Message Broker
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
KAFKA_BROKERS=kafka:9092

# Passport
PASSPORT_PRIVATE_KEY=
PASSPORT_PUBLIC_KEY=

# Service URLs (inter-service communication)
USER_SERVICE_URL=http://user-service:8002
PRODUCT_SERVICE_URL=http://product-service:8003
INVENTORY_SERVICE_URL=http://inventory-service:8004
ORDER_SERVICE_URL=http://order-service:8005

# Feature Flags
FEATURE_2FA=false
FEATURE_SOCIAL_LOGIN=false

# Webhook
WEBHOOK_SECRET=
WEBHOOK_URL=
