APP_NAME="KV Auth Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001
APP_TIMEZONE=UTC
APP_LOCALE=en

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=auth_service
DB_USERNAME=root
DB_PASSWORD=

# Redis
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# Cache & Session
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

# JWT Configuration
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=604800
JWT_ISSUER=https://auth.kv-enterprise.io
JWT_PRIVATE_KEY_PATH=storage/keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=storage/keys/jwt-public.pem
JWT_PRIVATE_KEY_PASSPHRASE=

# Auth Service
AUTH_SERVICE_MAX_DEVICES_PER_USER=10
AUTH_SERVICE_REVOCATION_PREFIX=revoke
AUTH_SERVICE_SUSPICIOUS_FAILED_ATTEMPTS=5
AUTH_SERVICE_SUSPICIOUS_LOCKOUT_MINUTES=15

# Rate Limiting
AUTH_RATE_LIMIT_LOGIN=10
AUTH_RATE_LIMIT_LOGIN_DECAY_MINUTES=1
AUTH_RATE_LIMIT_REFRESH=30
AUTH_RATE_LIMIT_REFRESH_DECAY_MINUTES=1

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_STACK=single

# Audit
AUDIT_LOG_RETENTION_DAYS=2555

# Service Identity (for service-to-service auth)
SERVICE_ID=auth-service
SERVICE_SECRET=
