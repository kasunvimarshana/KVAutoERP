APP_NAME="Auth Service"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8001
APP_VERSION=1.0.0

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ──────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=auth_service
DB_USERNAME=root
DB_PASSWORD=secret
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ──────────────────────────────────────────────────
# Cache & Session
# ──────────────────────────────────────────────────
BROADCAST_DRIVER=redis
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ──────────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=predis

# ──────────────────────────────────────────────────
# Mail
# ──────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ──────────────────────────────────────────────────
# Laravel Passport
# ──────────────────────────────────────────────────
PASSPORT_PRIVATE_KEY=
PASSPORT_PUBLIC_KEY=
PASSPORT_TOKEN_EXPIRY_DAYS=15
PASSPORT_REFRESH_TOKEN_EXPIRY_DAYS=30
PASSPORT_PERSONAL_ACCESS_TOKEN_EXPIRY_MONTHS=6

# ──────────────────────────────────────────────────
# Inter-service Communication
# ──────────────────────────────────────────────────
# Shared service token used by other microservices to call this auth service
SERVICE_TOKEN=

# Inventory service base URL
INVENTORY_SERVICE_URL=http://localhost:8002

# Notification service base URL
NOTIFICATION_SERVICE_URL=http://localhost:8003

# ──────────────────────────────────────────────────
# Tenant defaults
# ──────────────────────────────────────────────────
DEFAULT_TENANT_PLAN=free
TENANT_TRIAL_DAYS=14

# ──────────────────────────────────────────────────
# AWS (optional – for S3/SES in production)
# ──────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ──────────────────────────────────────────────────
# Pusher / Broadcasting
# ──────────────────────────────────────────────────
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
