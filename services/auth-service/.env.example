APP_NAME=AuthService
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8001

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=auth_db
DB_USERNAME=auth_user
DB_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

TENANT_SERVICE_URL=http://tenant-service:8002

# Passport RSA keys (base64-encoded or file path)
PASSPORT_PRIVATE_KEY=
PASSPORT_PUBLIC_KEY=

# Passport token TTL (minutes)
PASSPORT_TOKEN_EXPIRE_IN=60
PASSPORT_REFRESH_TOKEN_EXPIRE_IN=20160
PASSPORT_PERSONAL_ACCESS_TOKEN_EXPIRE_IN=525600

PASSPORT_PERSONAL_ACCESS_CLIENT_ID=
PASSPORT_PERSONAL_ACCESS_CLIENT_SECRET=

# SSO shared secret for cross-service token generation
SSO_SECRET=
