APP_NAME="KV Auth Service"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8001

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kv_auth
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PREFIX=kv_auth_

# JWT Configuration
JWT_SECRET=
JWT_ALGO=RS256
JWT_TTL=15
JWT_REFRESH_TTL=43200
JWT_PUBLIC_KEY_PATH=storage/keys/public.pem
JWT_PRIVATE_KEY_PATH=storage/keys/private.pem

# Laravel Passport
PASSPORT_PERSONAL_ACCESS_CLIENT_ID=
PASSPORT_PERSONAL_ACCESS_CLIENT_SECRET=

# Token Rotation
TOKEN_REFRESH_WINDOW_MINUTES=5
TOKEN_VERSION_INCREMENT_ON_PASSWORD_CHANGE=true

# Rate Limiting
RATE_LIMIT_LOGIN=5
RATE_LIMIT_REFRESH=10
RATE_LIMIT_REGISTER=3
RATE_LIMIT_DECAY_MINUTES=1

# Suspicious Activity Detection
MAX_FAILED_LOGINS=5
SUSPICIOUS_ACTIVITY_WINDOW_MINUTES=15
IP_CHANGE_DETECTION=true

# Multi-Tenancy
TENANT_ISOLATION_MODE=strict
DEFAULT_SESSION_TIMEOUT_MINUTES=480
MAX_DEVICES_PER_USER=10

# Service-to-Service Auth
SERVICE_AUTH_SECRET=
SERVICE_AUTH_TTL_MINUTES=5

# Outbox Pattern
OUTBOX_PROCESSING_INTERVAL_SECONDS=5
OUTBOX_MAX_RETRY_ATTEMPTS=3

# Message Broker (Kafka/RabbitMQ)
BROKER_DRIVER=rabbitmq
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_LOGIN=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_EXCHANGE_NAME=kv_auth_events

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="auth@kv-enterprise.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
