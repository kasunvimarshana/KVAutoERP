{
    "name": "kv-enterprise/inventory-service",
    "description": "Inventory Service microservice for KV Enterprise ERP/CRM SaaS Platform",
    "type": "project",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "predis/predis": "^2.0",
        "ramsey/uuid": "^4.0",
        "lcobucci/jwt": "^5.0",
        "lcobucci/clock": "^3.0",
        "kv-enterprise/shared-kernel": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "fakerphp/faker": "^1.23",
        "mockery/mockery": "^1.6"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../packages/shared-kernel"
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
