APP_NAME="KV Product Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8003

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql-product
DB_PORT=3306
DB_DATABASE=product_db
DB_USERNAME=product_user
DB_PASSWORD=secret

CACHE_DRIVER=redis
QUEUE_CONNECTION=rabbitmq
SESSION_DRIVER=redis

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

TENANT_ID=default

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

KAFKA_BROKERS=kafka:9092

AUTH_SERVICE_URL=http://auth-service:8001
INVENTORY_SERVICE_URL=http://inventory-service:8004
ORDER_SERVICE_URL=http://order-service:8005

PASSPORT_INTROSPECT_URL=http://auth-service:8001/api/auth/introspect
