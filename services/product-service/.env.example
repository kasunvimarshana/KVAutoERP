APP_NAME="Product Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8003

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=product_service
DB_USERNAME=root
DB_PASSWORD=

CACHE_DRIVER=redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

AUTH_SERVICE_URL=http://auth-service:8001

# JWT public key path (RSA PEM file — no private key needed in this service).
JWT_PUBLIC_KEY_PATH=/var/www/keys/oauth-public.key
JWT_ALGORITHM=RS256
JWT_LEEWAY_SECONDS=30

# Redis revocation list key prefixes (must match auth-service settings).
JWT_REVOCATION_JTI_PREFIX=jti:
JWT_REVOCATION_VERSION_PREFIX=token_version:

# Pagination
DEFAULT_PER_PAGE=15
MAX_PER_PAGE=100

# Product service defaults
DEFAULT_COST_METHOD=weighted_average
PRODUCT_IMAGE_DISK=public
PRODUCT_IMAGE_MAX_SIZE_KB=5120

