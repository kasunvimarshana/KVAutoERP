APP_NAME=ApiGateway
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# Downstream service URLs
AUTH_SERVICE_URL=http://auth-service:8001
TENANT_SERVICE_URL=http://tenant-service:8002
INVENTORY_SERVICE_URL=http://inventory-service:8003
ORDER_SERVICE_URL=http://order-service:8004
NOTIFICATION_SERVICE_URL=http://notification-service:8005

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_DECAY_MINUTES=1

# Gateway settings
GATEWAY_TIMEOUT=30
GATEWAY_RETRY_ATTEMPTS=1

CACHE_DRIVER=redis
LOG_CHANNEL=stack
LOG_LEVEL=debug
