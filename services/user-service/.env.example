APP_NAME="User Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8002

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=user_service
DB_USERNAME=root
DB_PASSWORD=

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0

JWT_PUBLIC_KEY_PATH=storage/keys/public.pem
JWT_LEEWAY_SECONDS=30
JWT_ALGORITHM=RS256
JWT_ISSUER=https://auth.kv-enterprise.io

USER_SERVICE_KEY=change-this-secret-key

REVOCATION_JTI_PREFIX=revoke:jti:
REVOCATION_VERSION_PREFIX=revoke:user:
REVOCATION_DEVICE_PREFIX=revoke:device:

LOG_CHANNEL=stack
LOG_LEVEL=debug

CACHE_DRIVER=redis
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
