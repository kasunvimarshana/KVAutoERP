APP_NAME="KV User Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8002

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql-user
DB_PORT=3306
DB_DATABASE=user_db
DB_USERNAME=user_svc_user
DB_PASSWORD=secret

CACHE_DRIVER=redis
QUEUE_CONNECTION=rabbitmq
SESSION_DRIVER=redis

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

TENANT_ID=default

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

AUTH_SERVICE_URL=http://auth-service:8001
PASSPORT_INTROSPECT_URL=http://auth-service:8001/api/auth/introspect
