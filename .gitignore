# ─── Laravel ──────────────────────────────────────────────────────────────────
/vendor/
/node_modules/
/public/hot
/public/storage
/storage/*.key
.env
.env.*
!.env.example
*.lock
Homestead.json
Homestead.yaml
auth.json
npm-debug.log
yarn-error.log
/.idea
/.vscode
*.swp
*.swo
.phpunit.result.cache
.phpunit.cache/

# ─── React / Node ─────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/build/
frontend/.env
frontend/.env.*
!frontend/.env.example
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

# ─── Docker ───────────────────────────────────────────────────────────────────
docker/mysql/data/
docker/nginx/ssl/*.pem
docker/nginx/ssl/*.crt
docker/nginx/ssl/*.key

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── IDE ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
nbproject/

# ─── Logs & Temp ─────────────────────────────────────────────────────────────
*.log
/tmp/
*.tmp
*.bak
*.orig

# ─── Composer ─────────────────────────────────────────────────────────────────
services/*/vendor/
services/*/composer.lock

# ─── Per-service .env files ───────────────────────────────────────────────────
services/*/.env
services/*/.env.*
!services/*/.env.example

# ─── Storage symlinks ─────────────────────────────────────────────────────────
services/*/public/storage
services/*/storage/logs/*.log
services/*/storage/framework/cache/data/*
services/*/storage/framework/sessions/*
services/*/storage/framework/testing/*
services/*/storage/framework/views/*
!services/*/storage/framework/.gitkeep
!services/*/storage/logs/.gitkeep
!services/*/storage/app/.gitkeep
