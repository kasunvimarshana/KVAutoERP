{
    "name": "saas/contracts",
    "description": "Shared PHP interfaces and DTOs for the SaaS Inventory Management System microservices",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Saas\\Contracts\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Saas\\Contracts\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
