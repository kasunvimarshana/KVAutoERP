NODE_ENV=development
PORT=3000

# MongoDB (different DB from PHP services)
MONGODB_URI=mongodb://notification_user:notification_pass@notification_db:27017/notification_db?authSource=admin

# RabbitMQ (shared message broker)
RABBITMQ_URL=amqp://admin:secret@rabbitmq:5672/

# Email (SMTP)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@saas.local

# Service identification
SERVICE_NAME=notification-service
