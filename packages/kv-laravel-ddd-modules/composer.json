{
    "name": "kasunvimarshana/kv-laravel-ddd-modules",
    "description": "A production-ready Laravel DDD modules package with CQRS support, dynamic configuration, and full Artisan command suite",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "ddd", "cqrs", "modules", "domain-driven-design"],
    "authors": [
        {
            "name": "Kasun Vimarshana",
            "email": "kasunvmail@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/filesystem": "^10.0|^11.0|^12.0",
        "illuminate/container": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "LaravelDDD\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaravelDDD\\Tests\\": "tests/",
            "LaravelDDD\\Examples\\": "examples/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaravelDDD\\DddServiceProvider"
            ],
            "aliases": {
                "Ddd": "LaravelDDD\\Facades\\Ddd"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
