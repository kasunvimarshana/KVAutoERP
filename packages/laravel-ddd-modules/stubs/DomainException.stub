<?php

namespace {{ namespace }}\Domain\Exceptions;

use RuntimeException;

class {{ module }}NotFoundException extends RuntimeException
{
    public function __construct(string $id, int $code = 0, ?\Throwable $previous = null)
    {
        parent::__construct(
            "{{ module }} with ID [{$id}] was not found.",
            $code,
            $previous
        );
    }

    public static function withId(string $id): self
    {
        return new self($id);
    }
}
