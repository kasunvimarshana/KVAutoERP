APP_NAME="Order Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8003

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=order_db
DB_PORT=3306
DB_DATABASE=order_db
DB_USERNAME=order_user
DB_PASSWORD=order_pass

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_DRIVER=redis
QUEUE_CONNECTION=rabbitmq

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=secret
RABBITMQ_VHOST=/

AUTH_SERVICE_URL=http://auth_service:8000
INVENTORY_SERVICE_URL=http://inventory_service:8000
NOTIFICATION_SERVICE_URL=http://notification_service:3000
