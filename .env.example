# =============================================================================
#  SaaS Inventory Management System – Environment Template
#  Copy to .env and fill in all values before running docker-compose up.
# =============================================================================

# -----------------------------------------------------------------------------
# Global Application Settings
# -----------------------------------------------------------------------------
APP_ENV=production
APP_DEBUG=false
CENTRAL_DOMAIN=saas.example.com

# Multi-tenant strategy: "domain" | "subdomain" | "path"
MULTI_TENANT_STRATEGY=subdomain

# -----------------------------------------------------------------------------
# MySQL (shared host, separate databases per service)
# -----------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=
MYSQL_USER=saas
MYSQL_PASSWORD=

# Per-service databases
AUTH_DB_DATABASE=auth_service_db
TENANT_DB_DATABASE=tenant_service_db
INVENTORY_DB_DATABASE=inventory_service_db
ORDER_DB_DATABASE=order_service_db
SAGA_DB_DATABASE=saga_orchestrator_db

# Shared database connection params (host/port resolved via Docker service name)
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=${MYSQL_USER}
DB_PASSWORD=${MYSQL_PASSWORD}

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Per-service Redis DB indices (0-15)
AUTH_REDIS_DB=1
TENANT_REDIS_DB=2
INVENTORY_REDIS_DB=3
ORDER_REDIS_DB=4
SAGA_REDIS_DB=5

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=saas
RABBITMQ_PASSWORD=
RABBITMQ_VHOST=saas_vhost

# Exchange / Queue names
RABBITMQ_EXCHANGE_EVENTS=saas.events
RABBITMQ_QUEUE_AUTH=auth.events
RABBITMQ_QUEUE_TENANT=tenant.events
RABBITMQ_QUEUE_INVENTORY=inventory.events
RABBITMQ_QUEUE_ORDER=order.events
RABBITMQ_QUEUE_NOTIFICATION=notification.events
RABBITMQ_QUEUE_SAGA=saga.commands

# -----------------------------------------------------------------------------
# Auth Service
# -----------------------------------------------------------------------------
AUTH_APP_KEY=base64:
AUTH_SERVICE_URL=http://auth-service
AUTH_SERVICE_INTERNAL_PORT=9000

# JWT / Laravel Passport
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160
JWT_ALGO=HS256

PASSPORT_PERSONAL_ACCESS_CLIENT_ID=
PASSPORT_PERSONAL_ACCESS_CLIENT_SECRET=

# OAuth Providers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://${CENTRAL_DOMAIN}/auth/github/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://${CENTRAL_DOMAIN}/auth/google/callback

# -----------------------------------------------------------------------------
# Tenant Service
# -----------------------------------------------------------------------------
TENANT_APP_KEY=base64:
TENANT_SERVICE_URL=http://tenant-service
TENANT_SERVICE_INTERNAL_PORT=9000

# Tenant isolation mode: "database" | "schema" | "row"
TENANT_ISOLATION_MODE=database

# Tenant provisioning
TENANT_DEFAULT_PLAN=free
TENANT_TRIAL_DAYS=14
TENANT_MAX_USERS_FREE=5
TENANT_MAX_USERS_PRO=50
TENANT_MAX_USERS_ENTERPRISE=unlimited

# Webhook config
WEBHOOK_SECRET=
WEBHOOK_TIMEOUT_SECONDS=30
WEBHOOK_MAX_RETRIES=5

# -----------------------------------------------------------------------------
# Inventory Service
# -----------------------------------------------------------------------------
INVENTORY_APP_KEY=base64:
INVENTORY_SERVICE_URL=http://inventory-service
INVENTORY_SERVICE_INTERNAL_PORT=9000

LOW_STOCK_THRESHOLD=10
INVENTORY_CACHE_TTL=300

# -----------------------------------------------------------------------------
# Order Service
# -----------------------------------------------------------------------------
ORDER_APP_KEY=base64:
ORDER_SERVICE_URL=http://order-service
ORDER_SERVICE_INTERNAL_PORT=9000

ORDER_TIMEOUT_MINUTES=30
ORDER_MAX_ITEMS_PER_ORDER=100

# Payment gateway
PAYMENT_GATEWAY=stripe
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Saga Orchestrator
# -----------------------------------------------------------------------------
SAGA_APP_KEY=base64:
SAGA_ORCHESTRATOR_URL=http://saga-orchestrator
SAGA_ORCHESTRATOR_INTERNAL_PORT=9000

SAGA_TIMEOUT_SECONDS=300
SAGA_MAX_RETRIES=3
SAGA_RETRY_DELAY_MS=1000

# -----------------------------------------------------------------------------
# Notification Service (Node.js)
# -----------------------------------------------------------------------------
NOTIFICATION_SERVICE_URL=http://notification-service:3000
NOTIFICATION_SERVICE_PORT=3000

# Mail (SMTP)
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@saas.example.com
MAIL_FROM_NAME="SaaS Inventory Platform"

# Mailgun (alternative)
MAILGUN_DOMAIN=
MAILGUN_SECRET=
MAILGUN_ENDPOINT=api.mailgun.net

# Slack
SLACK_WEBHOOK_URL=

# Firebase Cloud Messaging (push notifications)
FCM_SERVER_KEY=
FCM_SENDER_ID=

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# -----------------------------------------------------------------------------
# Inter-Service Communication
# -----------------------------------------------------------------------------
# All URLs are internal Docker network names (not public-facing)
SERVICE_AUTH_URL=http://auth-service
SERVICE_TENANT_URL=http://tenant-service
SERVICE_INVENTORY_URL=http://inventory-service
SERVICE_ORDER_URL=http://order-service
SERVICE_NOTIFICATION_URL=http://notification-service:3000
SERVICE_SAGA_URL=http://saga-orchestrator

# Internal service-to-service API key (shared secret)
INTERNAL_SERVICE_API_KEY=

# Circuit breaker settings
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=30
CIRCUIT_BREAKER_HALF_OPEN_REQUESTS=2

# -----------------------------------------------------------------------------
# API Gateway (Nginx)
# -----------------------------------------------------------------------------
GATEWAY_RATE_LIMIT_RPM=100
GATEWAY_BURST=20
GATEWAY_HTTP_PORT=80
GATEWAY_HTTPS_PORT=443

# -----------------------------------------------------------------------------
# Logging & Observability
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_LEVEL=error
LOG_DEPRECATIONS_CHANNEL=null

# Sentry (error tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=${APP_ENV}
SENTRY_TRACES_SAMPLE_RATE=0.1

# Prometheus metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_METRICS_PATH=/metrics
PROMETHEUS_NAMESPACE=saas_inventory

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=saas-inventory

# -----------------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------------
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=rabbitmq

# -----------------------------------------------------------------------------
# File Storage
# -----------------------------------------------------------------------------
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=saas-inventory-assets
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Local fallback
STORAGE_LOCAL_PATH=/var/www/html/storage/app/public

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=https://${CENTRAL_DOMAIN}

# Encryption key rotation (ISO 8601 date)
ENCRYPTION_KEY_ROTATION_DATE=

# Password policy
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SYMBOLS=true

# 2FA
TWO_FACTOR_ENABLED=true
TOTP_ISSUER="SaaS Inventory"
