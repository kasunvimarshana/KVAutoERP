# ============================================================
# Environment Configuration Template
# Copy to .env and fill in values
# ============================================================

# Application
APP_ENV=local
APP_DEBUG=true
LOG_LEVEL=debug

# Service App Keys (generate with: php artisan key:generate --show)
AUTH_APP_KEY=base64:GENERATE_ME
INVENTORY_APP_KEY=base64:GENERATE_ME
ORDER_APP_KEY=base64:GENERATE_ME

# MySQL
MYSQL_ROOT_PASSWORD=root_secret_password

# Auth Database
AUTH_DB_DATABASE=ims_auth
AUTH_DB_USERNAME=auth_user
AUTH_DB_PASSWORD=auth_db_secret

# Inventory Database
INVENTORY_DB_DATABASE=ims_inventory
INVENTORY_DB_USERNAME=inventory_user
INVENTORY_DB_PASSWORD=inventory_db_secret

# Order Database
ORDER_DB_DATABASE=ims_orders
ORDER_DB_USERNAME=order_user
ORDER_DB_PASSWORD=order_db_secret

# Payment Database (PostgreSQL)
PAYMENT_DB_DATABASE=ims_payments
PAYMENT_DB_USERNAME=payment_user
PAYMENT_DB_PASSWORD=payment_db_secret

# Redis
REDIS_PASSWORD=redis_secret_password

# Message Broker Driver: rabbitmq | kafka
MESSAGE_BROKER_DRIVER=rabbitmq

# RabbitMQ
RABBITMQ_USER=ims_user
RABBITMQ_PASSWORD=rabbitmq_secret

# Laravel Passport Keys (generate with: php artisan passport:keys --show)
PASSPORT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nGENERATE_ME\n-----END RSA PRIVATE KEY-----"
PASSPORT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nGENERATE_ME\n-----END PUBLIC KEY-----"

# Webhooks
WEBHOOK_SECRET=webhook_signing_secret
