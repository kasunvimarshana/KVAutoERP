# =============================================================================
# KV_SAAS – Inventory Management System – Environment Configuration
# Copy this file to .env and fill in the values for your environment.
# =============================================================================

# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME="KV Inventory SaaS"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_KEY=base64:CHANGE_ME_GENERATE_WITH_artisan_key_generate=

# ─── Service URLs (internal) ─────────────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:8001
TENANT_SERVICE_URL=http://localhost:8002
INVENTORY_SERVICE_URL=http://localhost:8003
ORDER_SERVICE_URL=http://localhost:8004
PAYMENT_SERVICE_URL=http://localhost:8005

# ─── MySQL ────────────────────────────────────────────────────────────────────
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=kv_saas
MYSQL_USERNAME=kv_user
MYSQL_PASSWORD=secret
MYSQL_ROOT_PASSWORD=rootsecret

# Per-service databases (overridden per service .env)
AUTH_DB_DATABASE=kv_auth
TENANT_DB_DATABASE=kv_tenants
INVENTORY_DB_DATABASE=kv_inventory
ORDER_DB_DATABASE=kv_orders
PAYMENT_DB_DATABASE=kv_payments

# DB connection pool
DB_CONNECTION=mysql
DB_POOL_MIN=2
DB_POOL_MAX=20

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redissecret
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_QUEUE_DB=3

# ─── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=kv_rabbit
RABBITMQ_PASSWORD=rabbitsecret
RABBITMQ_VHOST=/kv_saas
RABBITMQ_MANAGEMENT_PORT=15672

# Exchange / Queue settings
RABBITMQ_EXCHANGE=kv.saas.events
RABBITMQ_EXCHANGE_TYPE=topic
RABBITMQ_QUEUE_PREFIX=kv
RABBITMQ_DEAD_LETTER_EXCHANGE=kv.saas.dlx
RABBITMQ_PREFETCH_COUNT=10

# ─── Kafka ───────────────────────────────────────────────────────────────────
KAFKA_BROKER=kafka:9092
KAFKA_GROUP_ID=kv-saas-consumers
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_SESSION_TIMEOUT_MS=45000
KAFKA_TOPIC_PREFIX=kv.

# ─── Message Broker Driver ───────────────────────────────────────────────────
# Options: rabbitmq | kafka
MESSAGE_BROKER_DRIVER=rabbitmq

# ─── JWT / Passport ──────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING_HERE_REPLACE_IN_PRODUCTION_NOW
JWT_TTL=60
JWT_REFRESH_TTL=20160
JWT_ALGO=HS256
JWT_BLACKLIST_ENABLED=true

PASSPORT_CLIENT_ID=1
PASSPORT_CLIENT_SECRET=CHANGE_ME_PASSPORT_SECRET
PASSPORT_PERSONAL_ACCESS_CLIENT_ID=2
PASSPORT_PERSONAL_ACCESS_CLIENT_SECRET=CHANGE_ME_PERSONAL_ACCESS_SECRET

# ─── Multi-Tenancy ───────────────────────────────────────────────────────────
TENANT_ID=
TENANT_DB_PREFIX=tenant_
TENANT_IDENTIFICATION_DRIVER=header
# Options: header | subdomain | jwt_claim | path
TENANT_HEADER_NAME=X-Tenant-ID
TENANT_CACHE_TTL=300
TENANT_FALLBACK_CONNECTION=mysql

# ─── Cache ───────────────────────────────────────────────────────────────────
CACHE_DRIVER=redis
CACHE_PREFIX=kv_cache
CACHE_TTL=3600

# ─── Session ─────────────────────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=localhost

# ─── Queue ───────────────────────────────────────────────────────────────────
QUEUE_DRIVER=redis
QUEUE_CONNECTION=redis
QUEUE_DEFAULT=default
QUEUE_RETRY_AFTER=90
QUEUE_FAILED_TABLE=failed_jobs

# ─── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@kv-saas.local
MAIL_FROM_NAME="${APP_NAME}"

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_SLACK_WEBHOOK_URL=
LOG_DEPRECATIONS_CHANNEL=null

# ─── AWS (optional, for S3 storage / SES / SQS) ──────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Filesystem ──────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local
STORAGE_PATH=/var/www/html/storage

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Tenant-ID,X-Request-ID

# ─── Webhook ─────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_HMAC_SECRET
WEBHOOK_TIMEOUT=30
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY=60

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ─── Monitoring / Tracing ────────────────────────────────────────────────────
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=kv-saas
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1

# ─── Feature Flags ───────────────────────────────────────────────────────────
FEATURE_KAFKA_ENABLED=false
FEATURE_SAGA_ENABLED=true
FEATURE_WEBHOOK_ENABLED=true
FEATURE_RBAC_ENABLED=true
FEATURE_ABAC_ENABLED=true
