# Multi-tenant SaaS Inventory Management System - Environment Variables

# ──────────────────────────────────────────────
# RabbitMQ
# ──────────────────────────────────────────────
RABBITMQ_USER=admin
RABBITMQ_PASS=secret

# ──────────────────────────────────────────────
# Auth Service Database (MySQL)
# ──────────────────────────────────────────────
AUTH_DB_ROOT_PASSWORD=rootsecret
AUTH_DB_DATABASE=auth_db
AUTH_DB_USERNAME=auth_user
AUTH_DB_PASSWORD=auth_pass

# ──────────────────────────────────────────────
# Inventory Service Database (PostgreSQL)
# ──────────────────────────────────────────────
INVENTORY_DB_DATABASE=inventory_db
INVENTORY_DB_USERNAME=inventory_user
INVENTORY_DB_PASSWORD=inventory_pass

# ──────────────────────────────────────────────
# Order Service Database (MySQL)
# ──────────────────────────────────────────────
ORDER_DB_ROOT_PASSWORD=rootsecret
ORDER_DB_DATABASE=order_db
ORDER_DB_USERNAME=order_user
ORDER_DB_PASSWORD=order_pass

# ──────────────────────────────────────────────
# Notification Service Database (MongoDB)
# ──────────────────────────────────────────────
NOTIFICATION_DB_USERNAME=notification_user
NOTIFICATION_DB_PASSWORD=notification_pass
NOTIFICATION_DB_DATABASE=notification_db
