# ─────────────────────────────────────────────────────────────────────────────
# Global Application Settings
# ─────────────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false

# ─────────────────────────────────────────────────────────────────────────────
# Per-Service App Keys (generate with: php artisan key:generate --show)
# ─────────────────────────────────────────────────────────────────────────────
AUTH_APP_KEY=base64:REPLACE_ME
TENANT_APP_KEY=base64:REPLACE_ME
INVENTORY_APP_KEY=base64:REPLACE_ME
ORDER_APP_KEY=base64:REPLACE_ME
NOTIFICATION_APP_KEY=base64:REPLACE_ME
GATEWAY_APP_KEY=base64:REPLACE_ME

# ─────────────────────────────────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_AT_LEAST_64_CHARS

# ─────────────────────────────────────────────────────────────────────────────
# MySQL
# ─────────────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootsecret
MYSQL_USER=saas_user
MYSQL_PASSWORD=saas_password

# Per-service database credentials
AUTH_DB_PASSWORD=authsecret
TENANT_DB_PASSWORD=tenantsecret
INVENTORY_DB_PASSWORD=inventorysecret
ORDER_DB_PASSWORD=ordersecret
NOTIFICATION_DB_PASSWORD=notificationsecret

# ─────────────────────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redissecret

# ─────────────────────────────────────────────────────────────────────────────
# RabbitMQ
# ─────────────────────────────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ─────────────────────────────────────────────────────────────────────────────
# Kafka (optional alternative broker)
# ─────────────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092
MESSAGE_BROKER=rabbitmq

# ─────────────────────────────────────────────────────────────────────────────
# Mail (Notification Service)
# ─────────────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="SaaS Platform"

# ─────────────────────────────────────────────────────────────────────────────
# Frontend
# ─────────────────────────────────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────────────────────
# Tenant Settings
# ─────────────────────────────────────────────────────────────────────────────
TENANT_HEADER=X-Tenant-ID
TENANT_CACHE_TTL=3600
