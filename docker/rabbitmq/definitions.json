{
  "vhosts": [{ "name": "ims" }],
  "exchanges": [
    {
      "name": "ims.events",
      "vhost": "ims",
      "type": "topic",
      "durable": true,
      "auto_delete": false
    },
    {
      "name": "ims.dead_letter",
      "vhost": "ims",
      "type": "fanout",
      "durable": true,
      "auto_delete": false
    }
  ],
  "queues": [
    {
      "name": "inventory.events",
      "vhost": "ims",
      "durable": true,
      "arguments": {
        "x-dead-letter-exchange": "ims.dead_letter",
        "x-message-ttl": 86400000
      }
    },
    {
      "name": "order.events",
      "vhost": "ims",
      "durable": true,
      "arguments": {
        "x-dead-letter-exchange": "ims.dead_letter",
        "x-message-ttl": 86400000
      }
    },
    {
      "name": "payment.events",
      "vhost": "ims",
      "durable": true,
      "arguments": {
        "x-dead-letter-exchange": "ims.dead_letter",
        "x-message-ttl": 86400000
      }
    },
    {
      "name": "saga.events",
      "vhost": "ims",
      "durable": true,
      "arguments": {
        "x-dead-letter-exchange": "ims.dead_letter"
      }
    }
  ],
  "bindings": [
    {
      "source": "ims.events",
      "vhost": "ims",
      "destination": "inventory.events",
      "destination_type": "queue",
      "routing_key": "inventory.#"
    },
    {
      "source": "ims.events",
      "vhost": "ims",
      "destination": "order.events",
      "destination_type": "queue",
      "routing_key": "order.#"
    },
    {
      "source": "ims.events",
      "vhost": "ims",
      "destination": "payment.events",
      "destination_type": "queue",
      "routing_key": "payment.#"
    },
    {
      "source": "ims.events",
      "vhost": "ims",
      "destination": "saga.events",
      "destination_type": "queue",
      "routing_key": "saga.#"
    }
  ]
}
